# Groq API Configuration
# Get yours from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Configuration
# Get yours from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Twilio Credentials
# Get these from your Twilio Console: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# MongoDB Atlas
# Never commit real credentials - use placeholder
MONGO_URI=your_mongodb_uri_here
